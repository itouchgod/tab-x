{
  "manifest_version": 3,
  "name": "Tab X",
  "version": "2.0.0",
  "key": "",
  "description": "Keep tabs on your tabs. New tab page that groups your open tabs by domain and lets you close them with style.",
  "permissions": ["tabs", "activeTab", "storage", "topSites", "history", "search", "favicon"],
  "chrome_url_overrides": { "newtab": "index.html" },
  "background": { "service_worker": "background.js" },
  "action": {
    "default_title": "Tab X",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
